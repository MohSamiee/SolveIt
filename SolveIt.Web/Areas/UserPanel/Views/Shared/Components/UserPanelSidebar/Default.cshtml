@model UserPanelSidebarViewModel
@{
}

<div class="right-side">
    <!-- avatar -->
    <div class="quick-access layer-style">
        <div class="img-layer">

            <input type="file"
                   class="display-none"
                   name="avatarInput"
                   id="avatarInput"
                   accept="@(string.Join(", ", Model.AcceptableAvatarExtensions))"
                   onchange="changeAvatar(this)" />

            <a onclick="clickOnInput('avatarInput')" class="change-image">
                <i class="icon-pencil-edit"></i>
            </a>
            <img src="@PathTools.AvatarPath@Model.AvatarPath">
        </div>
        <!-- you can use "gold" , "silver , "bronze" for medals -->
        <div class="detail gold">
            <h3> <i class="icon-quality"></i> @Model.ShowName </h3>
            <span> عضویت : @Model.RegisterDate.ToPersianDate() </span>
            <span> کاربری طلایی با 1563 امتیاز </span>
        </div>
        <ul>
            <li><a href="" data-toggle="tooltip" data-placement="top" title="" data-original-title=" داشبورد "><i class="icon-settings"></i></a></li>
            <li><a href="" data-toggle="tooltip" data-placement="top" title="" data-original-title=" ویرایش اطلاعات "><i class="icon-profile"></i></a></li>
            <li><a href="" data-toggle="tooltip" data-placement="top" title="" data-original-title=" تغییر رمز عبور "><i class="icon-safe"></i></a></li>
            <li><a href="" data-toggle="tooltip" data-placement="top" title="" data-original-title=" خروج از حساب "><i class="icon-power-symbol"></i></a></li>
        </ul>
    </div>
    <!-- /avatar -->
    <!-- side bar -->
    <section class="sidebar layer-style">
        <header><h3> منوی دسترسی </h3><i class="icon-chevron-down"></i></header>
        <div class="inner">
            <ul>
                <li class="open">
                    <span> حساب کاربری </span>
                    <ul>

                        <li>
                            <a asp-area="UserPanel"
                               asp-controller="Home"
                               asp-action="Index">
                                @PropertyDictionary.UserPanel
                            </a>
                        </li>
                        <li><a href="account-1.html"> ویرایش حساب کاربری </a></li>
                        <li class="active"><a href="account-2.html"> تنظیمات حساب کاربری </a></li>
                        <li><a href="account-3.html"> تغییر رمز عبور </a></li>
                    </ul>
                    <label class="sign-dropdown"><i class="icon-chevron-down"></i></label>
                </li>
                <li><a href="account-4.html"> مدیریت رزومه  </a>  </li>
                <li><a href="account-5.html"> پرسش های من  </a> <i> 12 </i> </li>
                <li><a href="account-6.html"> پاسخ های من  </a> <i> 12 </i> </li>
                <li><a href="account-7.html"> دنبال کنندگان  </a> <i> 12 </i> </li>
                <li><a href="account-8.html"> دنبال شونده ها  </a> <i> 24 </i> </li>
                <li><a href="account-9.html"> صندوق پیام ها  </a> <i> 0 </i> </li>
                <li><a href="account-10.html"> سوالات متداول و راهنما  </a> </li>
            </ul>
        </div>
    </section>
    <!-- /side bar -->
    <!-- side bar -->
    <section class="sidebar layer-style open progress-account">
        <header><h3> تکمیل حساب کاربری </h3><i class="zmdi zmdi-chevron-down"></i></header>
        <div class="inner">
            <div class="complete-progress">
                <div id="progress" data-range="0.75"><canvas width="80" height="80"></canvas> <span>75%</span> </div>
            </div>

            <div class="detail">
                <span> 25% تا تکمیل حساب کاربری  </span>
            </div>
        </div>
    </section>
    <!-- /side bar -->
</div>
