{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "SolveItConnectionString": "Data Source=.;Initial Catalog=SolveItDb;Integrated Security=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "PasswordPolicy": {
    "MinLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireSpecialCharacter": false
  },
  "AvatarSetting": {
    "AcceptableExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ],
    "MaxFileSizeMb": "2",
    "AcceptableContentType": [ "image/jpeg", "image/png", "image/webp" ]
  },
  "ProductImageSetting": {
    "AcceptableExtensions": [ ".jpg", ".jpeg", ".png" ],
    "MaxFileSizeMb": "5",
    "AcceptableContentType": [ "image/jpeg", "image/png" ]
  },
  "PagingOptions": {
    "PageId": 1,
    "TakeEntity": 10,
    "HowManyShowPageAfterAndBefore": 3
  }
}
