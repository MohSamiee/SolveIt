@{
    ViewData["Title"] = PropertyDictionary.LandingPage;
}

@section Styles {
    <link rel="stylesheet" type="text/css" href="/css/home.css">
}

@section Header {
    <!-- lanfing page -->
    <div class="landing-layer">
        <div class="container">
            <header>
                <a href="" class="logo"><img src="/images/logo.svg"></a>
                <h1> سامانه <span>پرسش و پاسخ</span> برنامه نویسان و توسعه دهندگان </h1>
                <h2> آموزش ببینید ، مهارت ها و تخصص های خود را به اشتراک بگذارید ، بپرسید و به جواب برسید  </h2>
            </header>

            <div class="search-form">
                <form action="" method="">
                    <input type="text" name="" placeholder=" دنبال چه موضوعی میگردی ؟ ">
                    <button><i class="icon-search-1"></i></button>
                </form>
            </div>
        </div>
    </div>
    <!-- /lanfing page -->
    <!-- menu -->
    <div class="top-menu">
        <div class="container">

            <nav>
                <span><i class="icon-menu-2"></i></span>
                <ul>
                    <li><a href=""> تگ ها </a></li>
                    <li><a href=""> پرسش و پاسخ ها </a></li>
                    <li><a href=""> کاربران </a></li>
                    <li><a href=""> راهنمای سایت </a></li>
                </ul>
            </nav>

            <div class="clientarea-layer">
                <div class="loggedin-status hidden">
                    <i class="icon-profile"></i>
                    <span> حساب کاربری شما  </span>
                    <div class="sublayer">
                        <div class="avatar">
                            <a href=""><img src="/images/pic/avatar.jpg"></a>
                            <div>
                                <span class="fullname"> ایمان مدائنی </span>
                                <span class="detail"> 123 پرسش | 1236 پاسخ </span>
                            </div>
                        </div>
                        <ul>
                            <li><a href=""> مشاهده حساب کاربری </a></li>
                            <li><a href=""> تنظیمات حساب کاربری </a></li>
                            <li><a href=""> ویرایش حساب کاربری </a></li>
                            <li><a href=""> تغییر رمز عبور </a></li>
                            <li><a href=""> پرسش های من </a></li>
                            <li><a href=""> پاسخ های من </a></li>
                            <li><a href=""> خروج از حساب کاربری </a></li>
                        </ul>
                    </div>
                </div>
                <div class="signout-status ">
                    <i class="icon-profile"></i>
                    <a asp-area=""
                       asp-controller="Account"
                       asp-action="Login"> @PropertyDictionary.Login / </a>
                    <a asp-area=""
                       asp-controller="Account"
                       asp-action="Register"> @PropertyDictionary.Register </a>
                </div>
            </div>

            <div class="clearfix"></div>

        </div>
    </div>
    <!-- /menu -->
}

@section Scripts {
    <script src="/js/home.js"></script>
}



