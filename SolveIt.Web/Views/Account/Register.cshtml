@using SolveIt.Application.ViewModels.Accounts

@model RegisterViewModel
@{
    ViewData["Title"] = PropertyDictionary.Register;
}
@section Header {
    <partial name="_Header" />
}

@section Styles {
    <link rel="stylesheet" type="text/css" href="css/user.css">
}
<div class="user-page-style">

    <div class="breadcumb-layer">
        <div class="container">
            <ul class="breadcrumb">
                <li itemscope=""
                    itemprop="itemListElement">
                    <a href="/"
                       itemprop="item">
                        <span itemprop="name">
                            @PropertyDictionary.LandingPage
                        </span>
                    </a>
                </li>
                <li itemscope=""
                    itemprop="itemListElement">
                    <a asp-area=""
                       asp-controller="Account"
                       asp-action="Register"
                       itemprop="item">
                        <span itemprop="name">
                            @PropertyDictionary.Register
                        </span>
                    </a>
                </li>
            </ul>
        </div>
    </div>

    <div class="user-page">

        <div class="container">

            <div class="row">

                <div class="col-md-7 col-sm-12 col-xs-12 pull-left">

                    <div class="inner">
                        <div class="description">
                            <p> لطفا به هنگام ثبت نام به موارد زیر توجه فرمایید  </p>
                            <ul>
                                <li>ابتدا <a href="">قوانین و شرایط</a> عضویت در سامانه را با دقت مطالعه نموده و سپس اقدام به ثبت نام در سامانه نمایید .</li>
                                <li>لطفا مشخصات و شماره موبایل خود را با دقت و بطور صحیح وارد نمایید .</li>
                                <li>رمز عبور به سامانه پس از عضویت به شماره موبایل شما ارسال خواهد شد .</li>
                                <li>پس از ورود به حساب کاربری خود ، جهت حفظ امنیت بیشتر حساب کاربری ، لطفا رمز عبور خود را تغییر دهید .</li>
                            </ul>
                            <div class="register-link">
                                <i class="icon-login"></i> در صورتی که قبلا ثبت نام کرده اید ،  به حساب کاربری خود <a href=""> وارد شوید </a> .
                            </div>
                        </div>
                    </div>

                </div>

                <div class="col-md-5 col-sm-12 col-xs-12 pull-right">
                    <form asp-area=""
                          asp-controller="Account"
                          asp-action="Register"
                          method="post"
                          class="shadow-style">
                        <div class="inner">
                            <h2> <i class="icon-three-dots"></i> ثبت نام در سایت </h2>

                            <div class="input-layer">
                                <span>
                                    <i class="icon-mail-envelope"></i>
                                    @PropertyDictionary.Email
                                </span>
                                <input asp-for="Email" type="email">
                            </div>


                            <div class="input-layer">
                                <span>
                                    <i class="icon-lock-2"></i>
                                    @PropertyDictionary.Password
                                </span>
                                <input asp-for="Password" type="password" >
                            </div>

                            <div class="input-layer">
                                <span>
                                    <i class="icon-lock-2"></i>
                                    @PropertyDictionary.RePassword
                                </span>
                                <input asp-for="RePassword" type="password" >
                            </div>

                            <div class="captcha-layer">
                                <!-- کد کپچا در این لایه قرار بدید تا استایل بگیره-->
                            </div>

                            <button class="btn btn-primary"
                                    type="submit">
                                @PropertyDictionary.Register
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>